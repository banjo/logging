{
  "name": "@banjoanton/logging",
  "version": "0.0.0",
  "description": "Small structured logger for request-scoped wide events.",
  "author": "Anton Ödman <anton.odman@gmail.com>",
  "license": "MIT",
  "type": "module",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/banjo/logging#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/banjo/logging.git"
  },
  "bugs": "https://github.com/banjo/logging/issues",
  "sideEffects": false,
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "change:add": "changeset add",
    "change:version": "changeset version",
    "change:publish": "changeset publish"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^25.9.2",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "pino-pretty": "^13.1.3"
  }
}
